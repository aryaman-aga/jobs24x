# Environment variables for Jobs24x

# Django
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=.railway.app,.onrender.com,yourdomain.com

# Database (PostgreSQL)
DB_ENGINE=django.db.backends.postgresql
DB_NAME=jobs24x
DB_USER=jobs24x_user
DB_PASSWORD=your-strong-password
DB_HOST=localhost
DB_PORT=5432

# Email (SendGrid)
EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
SENDGRID_API_KEY=your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@jobs24x.com

# Keep-alive (prevent Render free-tier sleep)
# Set this to your app's public URL to auto-ping /health/ every 10 min
KEEP_ALIVE_URL=https://your-app.onrender.com

# Optional: for production static/media
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
